# Default daily limit for new API keys
NUXT_API_DEFAULT_LIMIT=10000

# Public site URL
NUXT_PUBLIC_SITE_URL=https://francis.verbatims.cc

# Session encryption (min 32 chars) — generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=

