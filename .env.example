# Default daily limit for new API keys
NUXT_API_DEFAULT_LIMIT=10000

# Public site URL
NUXT_PUBLIC_SITE_URL=https://francis.verbatims.cc

# Session encryption (min 32 chars) — generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=

# Admin credentials (used by seed script on first deploy)
NUXT_ADMIN_EMAIL=admin@verbatims.cc
NUXT_ADMIN_PASSWORD=

# OpenRouter API key for live translations
NUXT_OPENROUTER_API_KEY=
NUXT_OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Polar billing integration
NUXT_POLAR_ACCESS_TOKEN=
NUXT_POLAR_WEBHOOK_SECRET=
NUXT_POLAR_ORGANIZATION_ID=
NUXT_POLAR_SERVER=sandbox
NUXT_POLAR_CHECKOUT_SUCCESS_URL=https://francis.verbatims.cc/dashboard
